#cloud-config
package_update: true
package_upgrade: false
packages:
  - ca-certificates
  - curl
  - gnupg

write_files:
  - path: /opt/pronunt/docker-compose.yml
    permissions: "0644"
    content: |
      services:
        nginx:
          image: nginx:1.27-alpine
          restart: unless-stopped
          ports:
            - "80:80"
          volumes:
            - /opt/pronunt/nginx.conf:/etc/nginx/conf.d/default.conf:ro
          depends_on:
            - pronunt-frontend-service
            - pronunt-config-service
            - pronunt-aggregator-service
            - pronunt-worker-service
            - pronunt-ingestion-service
            - pronunt-ai-service
            - pronunt-auth-service

        mongodb-placeholder:
          image: busybox:1.36
          command: ["sh", "-c", "sleep infinity"]
          restart: unless-stopped

        rabbitmq:
          image: rabbitmq:3.13-management
          restart: unless-stopped
          healthcheck:
            test: ["CMD", "rabbitmq-diagnostics", "ping"]
            interval: 10s
            timeout: 5s
            retries: 20

        pronunt-config-service:
          image: ${images.config}
          restart: unless-stopped
          environment:
            APP_NAME: pronunt-config-service
            APP_ENV: production
            APP_HOST: 0.0.0.0
            APP_PORT: 8000
            MONGODB_URI: ${cosmos_mongo_uri}
            MONGODB_DATABASE: pronunt
            MONGODB_SERVICE_COLLECTION: config_services
            MONGODB_DEPENDENCY_COLLECTION: config_dependencies
            AUTH_ENABLED: "false"
            ALLOW_UNSAFE_DEV_AUTH: "true"

        pronunt-aggregator-service:
          image: ${images.aggregator}
          restart: unless-stopped
          environment:
            APP_NAME: pronunt-aggregator-service
            APP_ENV: production
            APP_HOST: 0.0.0.0
            APP_PORT: 8000
            MONGODB_URI: ${cosmos_mongo_uri}
            MONGODB_DATABASE: pronunt
            MONGODB_PR_COLLECTION: aggregator_pull_requests
            CONFIG_SERVICE_URL: http://pronunt-config-service:8000
            AI_SERVICE_URL: http://pronunt-ai-service:8000
            AUTH_ENABLED: "false"
            ALLOW_UNSAFE_DEV_AUTH: "true"
          depends_on:
            - pronunt-config-service

        pronunt-worker-service:
          image: ${images.worker}
          restart: unless-stopped
          environment:
            APP_NAME: pronunt-worker-service
            APP_ENV: production
            APP_HOST: 0.0.0.0
            APP_PORT: 8000
            RABBITMQ_URL: amqp://guest:guest@rabbitmq:5672/
            RABBITMQ_EXCHANGE: pronunt.events
            RABBITMQ_PR_ROUTING_KEY: pull_request.normalized
            RABBITMQ_PR_QUEUE: pronunt.pull_requests.normalized
            AGGREGATOR_SERVICE_URL: http://pronunt-aggregator-service:8000
            WORKER_CONSUMER_ENABLED: "true"
            AUTH_ENABLED: "false"
            ALLOW_UNSAFE_DEV_AUTH: "true"
          depends_on:
            rabbitmq:
              condition: service_healthy

        pronunt-ingestion-service:
          image: ${images.ingestion}
          restart: unless-stopped
          environment:
            APP_NAME: pronunt-ingestion-service
            APP_ENV: production
            APP_HOST: 0.0.0.0
            APP_PORT: 8000
            GITHUB_API_URL: https://api.github.com
            AUTH_SERVICE_URL: http://pronunt-auth-service:8000
            INTERNAL_SERVICE_TOKEN: ${internal_service_token}
            RABBITMQ_URL: amqp://guest:guest@rabbitmq:5672/
            RABBITMQ_EXCHANGE: pronunt.events
            RABBITMQ_PR_ROUTING_KEY: pull_request.normalized
            RABBITMQ_PR_QUEUE: pronunt.pull_requests.normalized
            AUTH_ENABLED: "false"
            ALLOW_UNSAFE_DEV_AUTH: "true"
          depends_on:
            rabbitmq:
              condition: service_healthy

        pronunt-ai-service:
          image: ${images.ai}
          restart: unless-stopped
          environment:
            APP_NAME: pronunt-ai-service
            APP_ENV: production
            APP_HOST: 0.0.0.0
            APP_PORT: 8000
            OPENAI_MODEL: gpt-5-mini
            OPENAI_API_KEY: ${openai_api_key}
            AUTH_ENABLED: "false"
            ALLOW_UNSAFE_DEV_AUTH: "true"

        pronunt-auth-service:
          image: ${images.auth}
          restart: unless-stopped
          environment:
            APP_NAME: pronunt-auth-service
            APP_ENV: production
            APP_HOST: 0.0.0.0
            APP_PORT: 8000
            MONGODB_URI: ${cosmos_mongo_uri}
            MONGODB_DATABASE: pronunt
            MONGODB_CONNECTION_COLLECTION: auth_github_connections
            GITHUB_API_URL: https://api.github.com
            GITHUB_OAUTH_AUTHORIZE_URL: https://github.com/login/oauth/authorize
            GITHUB_OAUTH_ACCESS_TOKEN_URL: https://github.com/login/oauth/access_token
            GITHUB_OAUTH_CLIENT_ID: ${github_client_id}
            GITHUB_OAUTH_CLIENT_SECRET: ${github_client_secret}
            GITHUB_OAUTH_REDIRECT_URI: https://pronunt.com/api/v1/auth/github/callback
            FRONTEND_AUTH_SUCCESS_URL: https://pronunt.com/connect
            FRONTEND_AUTH_FAILURE_URL: https://pronunt.com/connect
            SESSION_JWT_SECRET: ${session_jwt_secret}
            SESSION_JWT_ISSUER: pronunt-auth-service
            SESSION_TTL_SECONDS: 604800
            INTERNAL_SERVICE_TOKEN: ${internal_service_token}
            AUTH_ENABLED: "false"
            ALLOW_UNSAFE_DEV_AUTH: "true"

        pronunt-frontend-service:
          image: ${images.frontend}
          restart: unless-stopped
          environment:
            NODE_ENV: production
            PORT: 3000
            HOSTNAME: 0.0.0.0
          depends_on:
            - pronunt-aggregator-service
            - pronunt-config-service

      networks:
        default:
          name: pronunt-net

  - path: /opt/pronunt/nginx.conf
    permissions: "0644"
    content: |
      server {
        listen 80 default_server;
        server_name pronunt.com _;
        client_max_body_size 25m;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header X-Request-ID $request_id;

        location /api/v1/aggregator/ { proxy_pass http://pronunt-aggregator-service:8000; }
        location /api/v1/config/ { proxy_pass http://pronunt-config-service:8000; }
        location /api/v1/worker/ { proxy_pass http://pronunt-worker-service:8000; }
        location /api/v1/ingestion/ { proxy_pass http://pronunt-ingestion-service:8000; }
        location /api/v1/ai/ { proxy_pass http://pronunt-ai-service:8000; }
        location /api/v1/auth/ { proxy_pass http://pronunt-auth-service:8000; }
        location = /health { access_log off; return 200 "ok\n"; add_header Content-Type text/plain; }
        location / { proxy_set_header Upgrade $http_upgrade; proxy_set_header Connection "upgrade"; proxy_pass http://pronunt-frontend-service:3000; }
      }

runcmd:
  - |
    for attempt in 1 2 3 4 5; do
      curl -fsSL https://get.docker.com | sh && break
      sleep 30
    done
    command -v docker
  - usermod -aG docker azureuser
  - systemctl enable docker
  - systemctl start docker
  - |
    if [ -n "${container_registry_server}" ]; then
      echo "${container_registry_password}" | docker login "${container_registry_server}" --username "${container_registry_username}" --password-stdin
    fi
  - docker compose -f /opt/pronunt/docker-compose.yml up -d
